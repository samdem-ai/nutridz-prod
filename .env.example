# ============================================================
# NutriDz environment variables — copy to .env and fill in
# ============================================================

# ---- AI service (NVIDIA NIM) ----
# Get a free key at https://build.nvidia.com/
NVIDIA_API_KEY=your-nvidia-nim-key-here
NVIDIA_MODEL=mistralai/ministral-14b-instruct-2512
NVIDIA_VISION_MODEL=meta/llama-3.2-90b-vision-instruct

# ---- Spring Boot backend ----
# Generate a strong random string (32+ chars) for production
JWT_SECRET=change-me-to-a-256-bit-random-string-in-production
JWT_EXPIRATION=86400000

# MySQL (matches docker compose defaults)
SPRING_DATASOURCE_URL=jdbc:mysql://localhost:3306/nutridz_db?useSSL=false&serverTimezone=UTC&allowPublicKeyRetrieval=true
SPRING_DATASOURCE_USERNAME=nutridz_user
SPRING_DATASOURCE_PASSWORD=nutridz_pass

# RabbitMQ
SPRING_RABBITMQ_HOST=localhost
SPRING_RABBITMQ_PORT=5672
SPRING_RABBITMQ_USERNAME=nutridz_user
SPRING_RABBITMQ_PASSWORD=nutridz_pass

# Inter-service URL
AI_SERVICE_URL=http://localhost:8000
APP_BASE_URL=http://localhost:8080

# ---- Mobile app ----
# Set your laptop's LAN IP (run `ipconfig` on Windows or `ifconfig` on Mac/Linux)
# Used in apps/mobile/src/services/api.ts
EXPO_PUBLIC_API_BASE_URL=http://192.168.1.100:8080/api
